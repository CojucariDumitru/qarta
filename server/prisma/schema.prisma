generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
  role         String @default("ADMIN")
}

/// Singleton (id = 1): restaurant profile + AYCE pricing rules.
model Settings {
  id           Int     @id @default(1)
  name         String  @default("KAIYO")
  tagline      String  @default("Asian Grill & Sushi · All You Can Eat")
  aycePrice    Decimal @default(29.90) @db.Decimal(10, 2) // per person
  roundLimit   Int     @default(5) // AYCE items per person per round
  timeLimitMin Int     @default(90) // AYCE seating time limit
  guestCanOpen Boolean @default(true) // false = only staff seats guests (production mode)
}

model Category {
  id    String     @id @default(cuid())
  name  String     @unique
  sort  Int        @default(0)
  items MenuItem[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String
  ayce        Boolean     @default(true) // included in the AYCE price
  price       Decimal     @default(0) @db.Decimal(10, 2) // charged only when !ayce
  image       String
  available   Boolean     @default(true)
  popular     Boolean     @default(false)
  spicy       Boolean     @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Table {
  id       String         @id @default(cuid())
  number   Int            @unique
  code     String         @unique // public code in QR url: /m/:code
  seats    Int            @default(2)
  zone     String         @default("Main Hall")
  posX     Float          @default(10) // center, % of floor-plan viewBox width
  posY     Float          @default(10) // center, % of floor-plan viewBox height
  shape    String         @default("square") // round | square | rect
  sessions TableSession[]
  calls    WaiterCall[]
}

/// One seating: opened when the party starts, closed when they pay.
model TableSession {
  id       String    @id @default(cuid())
  tableId  String
  table    Table     @relation(fields: [tableId], references: [id])
  guests   Int       @default(2) // party size — multiplies the AYCE price
  status   String    @default("OPEN") // OPEN | CLOSED
  guestId  String? // attached loyalty card
  guest    Guest?    @relation(fields: [guestId], references: [id])
  discount Decimal   @default(0) @db.Decimal(10, 2)
  total    Decimal   @default(0) @db.Decimal(10, 2) // final bill, set at close
  openedAt DateTime  @default(now())
  closedAt DateTime?
  orders   Order[]
}

model Guest {
  id        String          @id @default(cuid())
  phone     String          @unique
  name      String?
  loyalty   LoyaltyAccount?
  sessions  TableSession[]
  createdAt DateTime        @default(now())
}

model LoyaltyAccount {
  id           String               @id @default(cuid())
  guestId      String               @unique
  guest        Guest                @relation(fields: [guestId], references: [id])
  points       Int                  @default(0) // 100 points = $1
  totalSpent   Decimal              @default(0) @db.Decimal(10, 2)
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id        String         @id @default(cuid())
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id])
  sessionId String?
  type      String // EARN | REDEEM
  points    Int
  createdAt DateTime       @default(now())
}

/// One round of ordering within a session.
model Order {
  id          String       @id @default(cuid())
  number      Int          @unique @default(autoincrement())
  sessionId   String
  session     TableSession @relation(fields: [sessionId], references: [id])
  status      String       @default("NEW") // NEW | DONE (all delivered) | CANCELLED
  extrasTotal Decimal      @default(0) @db.Decimal(10, 2) // priced (non-AYCE) items in this round
  comment     String?
  items       OrderItem[]
  createdAt   DateTime     @default(now())
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  name       String
  ayce       Boolean   @default(true)
  price      Decimal   @default(0) @db.Decimal(10, 2)
  qty        Int
  delivered  Boolean   @default(false) // waiter marks when brought to the table
}

model WaiterCall {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id])
  kind      String   @default("WAITER") // WAITER | BILL
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
}
