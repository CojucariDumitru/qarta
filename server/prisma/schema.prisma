generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String
  role         String @default("ADMIN")
}

model Category {
  id    String     @id @default(cuid())
  name  String     @unique
  sort  Int        @default(0)
  items MenuItem[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Decimal     @db.Decimal(10, 2)
  image       String
  available   Boolean     @default(true)
  popular     Boolean     @default(false)
  spicy       Boolean     @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Table {
  id      String       @id @default(cuid())
  number  Int          @unique
  code    String       @unique // short public code in QR url: /m/:code
  seats   Int          @default(2)
  zone    String       @default("Зал")
  posX    Float        @default(10) // center, % of floor-plan viewBox width
  posY    Float        @default(10) // center, % of floor-plan viewBox height
  shape   String       @default("square") // round | square | rect
  orders  Order[]
  calls   WaiterCall[]
}

model Guest {
  id      String         @id @default(cuid())
  phone   String         @unique
  name    String?
  loyalty LoyaltyAccount?
  orders  Order[]
  createdAt DateTime     @default(now())
}

model LoyaltyAccount {
  id           String    @id @default(cuid())
  guestId      String    @unique
  guest        Guest     @relation(fields: [guestId], references: [id])
  points       Int       @default(0) // 100 points = $1
  totalSpent   Decimal   @default(0) @db.Decimal(10, 2)
  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id        String         @id @default(cuid())
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id])
  orderId   String?
  type      String // EARN | REDEEM
  points    Int
  createdAt DateTime       @default(now())
}

model Order {
  id        String      @id @default(cuid())
  number    Int         @unique @default(autoincrement())
  tableId   String
  table     Table       @relation(fields: [tableId], references: [id])
  guestId   String?
  guest     Guest?      @relation(fields: [guestId], references: [id])
  status    String      @default("NEW") // NEW | ACCEPTED | PREPARING | SERVED | PAID | CANCELLED
  subtotal  Decimal     @db.Decimal(10, 2)
  discount  Decimal     @default(0) @db.Decimal(10, 2) // from redeemed points
  total     Decimal     @db.Decimal(10, 2)
  comment   String?
  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model OrderItem {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id])
  name       String
  price      Decimal   @db.Decimal(10, 2)
  qty        Int
}

model WaiterCall {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id])
  status    String   @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime @default(now())
}
